-	[ $? = 0 ] && echo "OK" || echo "FAIL"
+	start-stop-daemon -K -q -p /var/run/dropbear.pid || pkill -f /usr/sbin/dropbear >/dev/null 2>&1
+	printf 'OK\n'
 }
+
 restart() {
 	stop
 	start
 }
 
 case "$1" in
-  start)
-  	start
-	;;
-  stop)
-  	stop
-	;;
-  restart|reload)
-  	restart
-	;;
+  start)          start ;;
+  stop)           stop  ;;
+  restart|reload) stop; start ;;
   *)
-	echo "Usage: $0 {start|stop|restart}"
+	printf 'Usage: %s {start|stop|restart}\n' "${0##*/}" >&2
 	exit 1
 esac
-
-exit $?
