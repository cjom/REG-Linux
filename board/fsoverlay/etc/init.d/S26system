#!/bin/dash

ba_keyboard_lang() {
    loadkeys "$(/usr/bin/system-settings-get system.kblayout 2>/dev/null || echo 'us')"
}

ba_timezone() {
    settings_timezone=$(/usr/bin/system-settings-get system.timezone 2>/dev/null)
    [ -n "$settings_timezone" ] && /usr/bin/system-config tz "$settings_timezone"
}

ba_hostname() {
    settings_hostname=$(/usr/bin/system-settings-get system.hostname 2>/dev/null)
    current_hostname=$(hostname)
    echo "Hostname after DHCP setup is: ${current_hostname}"
    if [ -n "$settings_hostname" ]; then
        echo "Setting hostname from system.hostname: ${settings_hostname}"
        hostname "$settings_hostname"
        current_hostname="$settings_hostname"
    else
        echo "No system.hostname value is set, leaving hostname unchanged"
    fi
    if [ -n "$current_hostname" ]; then
        echo "Creating /etc/hosts"
        printf '%s\t%s\n' "127.0.0.1" "localhost" > /etc/hosts
        printf '%s\t%s\n' "127.0.1.1" "$current_hostname" >> /etc/hosts
    fi
}

ba_xarcade2jstick() {
    settings_xarcade=$(/usr/bin/system-settings-get controllers.xarcade.enabled 2>/dev/null)
    if [ "$settings_xarcade" = "1" ] && ! /usr/bin/xarcade2jstick -d >/dev/null 2>&1; then
        for dev in /usr/share/reglinux/datainit/system/configs/xarcade2jstick/*; do
            [ -e "$dev" ] || continue
            devname=$(basename "$dev")
            [ -h "/dev/input/by-id/$devname" ] && /usr/bin/xarcade2jstick -d -e "/dev/input/by-id/$devname" >/dev/null 2>&1 && break
        done
    fi
}

ba_es_core_dump() {
    sysctl -w kernel.core_pattern=/userdata/system/logs/core.%e >/dev/null 2>&1
}

case "$1" in
  start)
    printf "Starting system: "
    # Run async tasks in background
    ba_keyboard_lang &
    ba_timezone &
    ba_xarcade2jstick &
    ba_es_core_dump &
    # Run critical task synchronously
    ba_hostname > /userdata/system/logs/hostname.log
    # Wait for all background jobs
    wait
    echo "done."
    ;;
  stop|restart|reload)
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|reload}" >&2
    exit 1
    ;;
esac
