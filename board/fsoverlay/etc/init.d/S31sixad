#!/bin/dash
case "$1" in
    start)
        { [ "$(/usr/bin/system-settings-get controllers.ps3.enabled)" = "1" ] && [ "$(/usr/bin/system-settings-get controllers.bluetooth.enabled)" = "1" ]; } || exit 0
        settings_version=$(/usr/bin/system-settings-get controllers.ps3.driver)
        [ "$settings_version" = "bluez" ] && exit 0                      # Exit early if bluez — no action needed
        [ -z "$settings_version" ] && settings_version="official"        # Default to "official" if empty
        exec "/usr/sixad/$settings_version/sixad-bin" 0 0 0 >/dev/null 2>&1 &
        ;;
    stop)
        { pkill -f sixad-bin; pkill -f sixad-sixaxis; } >/dev/null 2>&1
        ;;
    restart|reload)
        # Call functions directly instead of forking new shell processes
        set -- stop
        . "$0"
        set -- start
        . "$0"
        ;;
    *)
        printf '%s\n' "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac
