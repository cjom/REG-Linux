#!/bin/dash
REGCONF="/userdata/system/system.conf"
BOOTCONF="/boot/system-boot.conf"
CR=$(printf '\r')

if [ -f "$REGCONF" ]; then
    # Remove carriage returns from .conf files
    grep -q "$CR" "$REGCONF" 2>/dev/null && tr -d '\r' < "$REGCONF" > /tmp/conf.tmp && mv /tmp/conf.tmp "$REGCONF"
else
    REGCONF="$BOOTCONF"    # if /userdata is not yet available use /boot
    if grep -q "$CR" "$REGCONF"; then
        if mount -o remount,rw /boot; then
            tr -d '\r' < "$REGCONF" > /tmp/conf.tmp && mv /tmp/conf.tmp "$REGCONF" && mount -o remount,ro /boot
        else
            printf 'Error: %s has invalid charactes (CR) but could not remount /boot in rw mode' "$BOOTCONF"
        fi
    fi
fi

settingsWlan=$(/usr/bin/system-settings-get -f "$REGCONF" wifi.enabled)

# Set initial hostname, to be sent in connman DHCP Request
#
# Note that if the DHCP server sends back a hostname, connman will set
# that as the system hostname.
#
# Later in the boot process, /etc/init.d/S26system will then reset the
# hostname to the value specified in the system.hostname setting
# ("REGLINUX" by default), but will do so *only* if the
# system.hostname setting is absent or blank.
#
# This leaves the user in control of the hostname to be set, and also
# lets the user allow for dynamic hostname configuration from DHCP, by
# setting the system.hostname setting to a blank empty string.
system_hostname() {
    printf 'Starting initial hostname configuration... '
    settings_hostname=$(/usr/bin/system-settings-get -f "$REGCONF" system.hostname)
    if [ -n "$settings_hostname" ]; then
        printf '\nSetting initial hostname from system.hostname (%s)... ' "${settings_hostname}"
        hostname="$settings_hostname"
    else
        printf '\nSetting default initial hostname (REGLINUX)... '
        hostname="REGLINUX"
    fi
    hostname "$hostname"
}

system_wifi_configure() {
    X=$1
    # Set defaults
    settings_hide=false
    settings_name="$X"
    case "$X" in
        1)       X=; settings_name="default";;
        .hidden) settings_name="hidden_AP"; settings_hide=true;;
    esac
    settings_ssid=$(/usr/bin/system-settings-get -f "$REGCONF" "wifi${X}.ssid")
    settings_key=$(/usr/bin/system-settings-get -f "$REGCONF" "wifi${X}.key")
    settings_file="/var/lib/connman/system_wifi${X}.config"

    # Create or remove config based on SSID and WLAN status
    if [ -n "$settings_ssid" ]; then
        if [ -n "$settings_key" ]; then 
            printf '%s\n' \
                "[global]" \
                "Name=system" \
                "[service_system_${settings_name}]" \
                "Type=wifi" \
                "Name=${settings_ssid}" \
                "Hidden=${settings_hide}" \
                "Passphrase=$settings_key" \
                "Autoconnect=true" \
                > "$settings_file"
        else
            printf '%s\n' \
                "[global]" \
                "Name=system" \
                "[service_system_${settings_name}]" \
                "Type=wifi" \
                "Name=${settings_ssid}" \
                "Hidden=${settings_hide}" \
                "Autoconnect=true" \
                > "$settings_file"
        fi
    else
        rm -f "$settings_file"
    fi
}

wifi_configure_all() {
    system_wifi_configure 1
    system_wifi_configure 2
    system_wifi_configure 3
    system_wifi_configure .hidden
}

wifi_enable() {
    settingsCountry=$(/usr/bin/system-settings-get -f "$REGCONF" wifi.country)
    [ -n "$settingsCountry" ] && /usr/sbin/iw reg set "$settingsCountry"
    connmanctl enable wifi >/dev/null 2>&1
    connmanctl scan wifi >/dev/null 2>&1
}

wait_for_connman() {
    i=0
    while [ $i -lt 20 ]; do
        connmanctl state 2>/dev/null | grep -qE '^[[:space:]]*State[[:space:]]=' && return 0
        sleep 0.25
        i=$((i + 1))
    done
    return 1
}

do_stop() {
    printf "Stopping connman: "
    start-stop-daemon -K -q -p /var/run/connmand.pid >/dev/null 2>&1
    echo "done."
}

case "$1" in
    start)
        system_hostname
        [ "$settingsWlan" = "1" ] && wifi_configure_all
        printf "Starting connman: "
        start-stop-daemon -S -q -m -b -p /var/run/connmand.pid --exec /usr/sbin/connmand -- -n -r
        if wait_for_connman; then
            if [ "$settingsWlan" = "1" ]; then
                wifi_enable &
            else
                connmanctl disable wifi >/dev/null 2>&1 &
            fi
            echo "done."
        else
            printf "timeout waiting for connman [error].\n" >&2
        fi
        ;;
    stop)
        do_stop
        ;;
    restart|reload)
        do_stop
        sleep 0.5
        exec "$0" start
        ;;
    *)
        printf 'usage: %s {start|stop|restart|reload}\n' "$0"
        exit 1
        ;;
esac
