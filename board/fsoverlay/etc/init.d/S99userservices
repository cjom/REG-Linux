#!/bin/dash

# Service names consists only of letters, digits, and underscores, and starts with a letter or underscore.
is_valid_service_name() {
    case $1 in
        [_[:alpha:]][_[:alnum:]]*) return 0 ;;
        *)                         return 1 ;;
    esac
}

process_services() {
    service_type="$1"
    service_dir="$2"
    service_state="$3"

    # Use -print0 and while IFS= read -r to handle filenames with spaces/special chars
    find -L "$service_dir" -type f -print | while IFS= read -r SERVICE; do
        BASE_SERVICE=${SERVICE##*/}
        if is_valid_service_name "$BASE_SERVICE"; then
            SRVVAR="__SERVICE__$BASE_SERVICE"
            eval "val=\$$SRVVAR"
            if [ "$val" = 1 ]; then
                # If executable bit set, call directly. Else, use dash.
                if [ -x "$SERVICE" ]; then
                    "$SERVICE" "$service_state" &
                else
                    /bin/dash "$SERVICE" "$service_state" &
                fi






#
#
# remove " | tee /dev/kmsg" after debug
#
#



                printf '%s Service: %s -> service is enabled [ok]\n' "$service_type" "$BASE_SERVICE" | tee /dev/kmsg
            else
                printf '%s Service: %s -> service is disabled [ok]\n' "$service_type" "$BASE_SERVICE" | tee /dev/kmsg
            fi
        else
            # Suggest name: remove invalid chars, strip leading digits
            # Step 1: Remove all invalid characters
            temp=$(printf '%s' "$BASE_SERVICE" | tr -cd '_[:alnum:]')
            # Step 2: Remove leading digits (loop until no leading digit)
            while case $temp in [0-9]*) true;; *) false;; esac; do
                temp=${temp#?}
            done
            BASE_SERVICE_SUGGEST=${temp:-service}
            printf '%s Service: %s [failed] -> invalid service name, suggest rename service file to: "%s"\n' "$service_type" "$BASE_SERVICE" "$BASE_SERVICE_SUGGEST"
        fi
    done
}

enabled_services="$(/usr/bin/system-settings-get system.services)"
if [ -n "$enabled_services" ]; then
    for SERVICE in $enabled_services; do
        eval "export __SERVICE__${SERVICE}=1"
    done
fi

# user services
process_services User /userdata/system/services "$1"

# system user services
process_services System /usr/share/reglinux/services "$1"

# wait for spawned scripts to finish on stop condition
[ "$1" = "stop" ] && wait
[ "$1" = "start" ] && echo "S99services: BOOT FINISHED" > /dev/kmsg
