#!/bin/dash
command -v system-brightness >/dev/null 2>&1 || exit 0
case $1 in
    start)
        bri=$(/usr/bin/system-settings-get display.brightness 2>/dev/null)
        [ -z "$bri" ] && exit 0
        # Clamp brightness to minimum 5
        [ "$bri" -lt 5 ] && bri=5
        system-brightness "$bri"
        ;;
    stop)
        current=$(system-brightness 2>/dev/null)
        stored=$(/usr/bin/system-settings-get display.brightness 2>/dev/null)
        [ "$current" != "$stored" ] && /usr/bin/system-settings-set display.brightness "$current"
        ;;
esac
