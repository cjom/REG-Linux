config BR2_PACKAGE_BATOCERA_MSDOS_SYSTEMS
	bool "batocera.linux MS/DOS emulation packages"

	select BR2_PACKAGE_DOSBOX_X				if !BR2_PACKAGE_SYSTEM_TARGET_JZ4770  && \
